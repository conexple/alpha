# =============================================================================

# IDE / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing / coverage
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/

