# Frontend (Next.js) — public env vars only.
# Copy to .env.local for dev, .env.production for prod build.

NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_OPERATOR_URL=https://conexple-worker-operator.sornwin.workers.dev
NEXT_PUBLIC_NETWORK_ID=1

# Filled in after `anchor deploy` + `anchor keys list`
NEXT_PUBLIC_PROGRAM_PROTOCOL=
NEXT_PUBLIC_PROGRAM_NETWORK=
NEXT_PUBLIC_PROGRAM_ESCROW=
NEXT_PUBLIC_PROGRAM_ORACLE=

# Filled in after `pnpm exec tsx scripts/mint-demo-usdc.ts`
NEXT_PUBLIC_DEMO_USDC_MINT=
