# =============================================================================
# Conexple — environment variables (template)
# Copy to ".env" at repo root for local dev. NEVER commit ".env".
# Production / hosted secrets live in Cloudflare Secrets, not here.
# =============================================================================

# --- Solana ---
SOLANA_CLUSTER=devnet
# Helius free-tier devnet RPC, or public devnet fallback:
# https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com
NETWORK_ID=1

# Path to a Solana keypair JSON file that will deploy the programs.
# Generate: solana-keygen new -o keys/devnet-deployer.json
ANCHOR_WALLET=keys/devnet-deployer.json

# --- Program IDs (set after first `anchor deploy` + `anchor keys list`) ---
PROGRAM_ID_PROTOCOL=
PROGRAM_ID_NETWORK=
PROGRAM_ID_ESCROW=
PROGRAM_ID_ORACLE=

# --- Demo USDC mint (set after running scripts/mint-demo-usdc.ts) ---
DEMO_USDC_MINT=

# --- Operator (Cloudflare Worker secrets — set via `wrangler secret put`) ---
# These should NEVER appear in code or in the deployed bundle.
# Listed here only so the developer knows what to provision.
# generate ORACLE_SECRET: solana-keygen new --no-bip39-passphrase -o keys/oracle-devnet.json
#   then bs58-encode: node -e "const k=require('./keys/oracle-devnet.json'); const bs58=require('bs58'); console.log(bs58.default.encode(Uint8Array.from(k)))"
ORACLE_SECRET=
HELIUS_RPC_URL=
PURCHASE_WEBHOOK_HMAC=

# --- Cloudflare resource IDs (already provisioned for SORNKan Co., Ltd.) ---
# These are NOT secrets. Documented here for reproducibility.
CF_ACCOUNT_ID=a24ce30584273b42333051f1cdec48e2
CF_D1_DATABASE_ID=71f8087c-7f63-415e-a92d-d6d577a7d49e
CF_KV_NAMESPACE_ID=69a3584be9e846dcb3c81f33ef324376
CF_QUEUE_NAME=conexple-queue-purchase-events
# Cloudflare API token with D1:Edit + KV:Edit (only needed for `drizzle-kit generate`):
CF_API_TOKEN=

# --- Frontend (PUBLIC — these CAN appear in the bundle) ---
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_OPERATOR_URL=https://conexple-worker-operator.workers.dev
NEXT_PUBLIC_NETWORK_ID=1
NEXT_PUBLIC_PROGRAM_PROTOCOL=
NEXT_PUBLIC_PROGRAM_NETWORK=
NEXT_PUBLIC_PROGRAM_ESCROW=
NEXT_PUBLIC_PROGRAM_ORACLE=
NEXT_PUBLIC_DEMO_USDC_MINT=

# --- Local-only convenience ---
DEV_PURCHASE_WEBHOOK_URL=http://localhost:8787/webhook/purchase
