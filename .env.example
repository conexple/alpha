# =============================================================================
# Conexple — environment variables (template)
# Copy to ".env" at repo root for local dev. NEVER commit ".env".
# Production / hosted secrets live in Cloudflare Secrets, not here.
# =============================================================================

# --- Solana ---
SOLANA_CLUSTER=devnet
# Helius free-tier devnet RPC, or public devnet fallback:
# https://api.devnet.solana.com
SOLANA_RPC_URL=

# Path to a Solana keypair JSON file that will deploy the programs.
# Generate: solana-keygen new -o ~/.config/solana/devnet-deployer.json
ANCHOR_WALLET=~/.config/solana/devnet-deployer.json

# --- Program IDs (set after first `anchor deploy`) ---
PROGRAM_ID_PROTOCOL=
PROGRAM_ID_NETWORK=
PROGRAM_ID_ESCROW=
PROGRAM_ID_ORACLE=

# --- Operator (Cloudflare Worker secrets — set via `wrangler secret put`) ---
# These should NEVER appear in code or in the deployed bundle.
# Listed here only so the developer knows what to provision.
ORACLE_SECRET=                  # base58-encoded Solana keypair for the oracle signer
HELIUS_RPC_URL=                 # devnet RPC with API key — fronted by rpc-cache worker
PURCHASE_WEBHOOK_HMAC=          # shared secret with the demo storefront
DEMO_USDC_MINT=                 # mock USDC token-2022 mint pubkey (set after seed)

# --- Frontend (PUBLIC values — these CAN appear in the bundle) ---
NEXT_PUBLIC_RPC_URL=https://rpc.conexple.workers.dev/rpc
NEXT_PUBLIC_NETWORK_ID=         # demo network PDA pubkey
NEXT_PUBLIC_PROGRAM_PROTOCOL=
NEXT_PUBLIC_PROGRAM_NETWORK=
NEXT_PUBLIC_PROGRAM_ESCROW=
NEXT_PUBLIC_PROGRAM_ORACLE=
NEXT_PUBLIC_DEMO_USDC_MINT=

# --- D1 / KV / Queues bindings (set in wrangler.toml, not here) ---
# D1_DATABASE_ID=...            # see wrangler.toml
# KV_NAMESPACE_ID=...           # see wrangler.toml

# --- Local-only convenience ---
# DEV_PURCHASE_WEBHOOK_URL=http://localhost:8787/webhook/purchase
